# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/immigration_mcp

# Server
MCP_SERVER_NAME=immigration-navigator
MCP_SERVER_VERSION=0.1.0
DATA_INDEXED_DATE=2026-03-14

# MCP Transport: "stdio" (default, for Claude Desktop / local) or "sse" (for Docker / remote)
MCP_TRANSPORT=stdio

# LLM Summarization (for PageIndex construction — Phase 2b)
# Provider: "gemini" (default, free tier), "openai", or "custom"
LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-2.0-flash-lite
# LLM_BASE_URL=  # Auto-set for gemini/openai. Override for custom providers.
LLM_RPM=14
# LLM_MAX_RETRIES=3
